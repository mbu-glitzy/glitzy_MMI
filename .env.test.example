# E2E 테스트 환경변수 예시
# 이 파일을 .env.test로 복사하고 실제 값을 입력하세요

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-test-secret-key

# Supabase (테스트용 또는 개발 환경)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# E2E 테스트 계정
E2E_SUPERADMIN_EMAIL=admin@glitzy.co.kr
E2E_SUPERADMIN_PASSWORD=your-test-password
E2E_CLINIC_EMAIL=clinic@test.com
E2E_CLINIC_PASSWORD=your-clinic-password

# Playwright 설정
PLAYWRIGHT_BASE_URL=http://localhost:3000
